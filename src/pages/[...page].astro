---
import type { GetStaticPaths } from "astro";
import Pagination from "../components/control/Pagination.astro";
import PostPage from "../components/PostPage.astro";
import { Icon } from "astro-icon/components";
import { PAGE_SIZE } from "../constants/constants";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { getSortedPosts } from "../utils/content-utils";
import { initPostIdMap } from "../utils/permalink-utils";
import { siteConfig } from "../config";

export const getStaticPaths = (async ({ paginate }) => {
	const allBlogPosts = await getSortedPosts();
	// 初始化文章 ID 映射（用于 permalink 功能）
	initPostIdMap(allBlogPosts);

	// 首页只显示置顶文章时，过滤出 pinned 的文章
	const homePageMode = siteConfig.homePageMode ?? "all";
	const postsForHome =
		homePageMode === "pinned_only"
			? allBlogPosts.filter((p) => p.data.pinned)
			: allBlogPosts;

	return paginate(postsForHome, { pageSize: PAGE_SIZE });
}) satisfies GetStaticPaths;
// https://github.com/withastro/astro/issues/6507#issuecomment-1489916992

const { page } = Astro.props;

const len = page.data.length;
const isEmpty = len === 0;
---

<MainGridLayout>
	{isEmpty ? (
		<div
			class="rounded-(--radius-large) bg-(--card-bg) p-12 text-center onload-animation"
			style="--content-delay: 0ms"
		>
			<Icon
				name="material-symbols:article-outline"
				class="mx-auto mb-4 text-6xl text-(--content-meta)"
			/>
			<p class="text-lg text-90 mb-2">暂无置顶文章</p>
			<p class="text-sm text-50 mb-6">全部文章请前往归档查看</p>
			<a
				href="/archive/"
				class="btn-regular inline-flex items-center gap-2 rounded-xl px-6 py-3"
			>
				<Icon name="material-symbols:archive" class="text-lg" />
				去归档
			</a>
		</div>
	) : (
		<>
			<PostPage page={page}></PostPage>
			<Pagination
				class="mx-auto onload-animation"
				page={page}
				style={`animation-delay: calc(var(--content-delay) + ${len * 50}ms)`}
			></Pagination>
		</>
	)}
</MainGridLayout>
